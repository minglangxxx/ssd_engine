# ============================================================
# Agent 服务配置
# ============================================================

# Agent HTTP 服务监听地址  默认: 0.0.0.0
AGENT_HOST=0.0.0.0

# Agent HTTP 服务监听端口  默认: 8080
AGENT_PORT=8080

# Agent 版本号，通过 /health 接口返回
AGENT_VERSION=0.3.0

# ============================================================
# Backend 数据上报配置
# ============================================================

# Backend 服务地址，留空则禁用数据上报（监控数据仅保留在内存 RingBuffer 中）  默认: 空
BACKEND_URL=http://127.0.0.1:5000

# 本机设备 IP，必须与 Backend devices 表中该设备的 ip 字段完全一致
# 留空时自动探测，但多网卡环境下可能探测错误，建议显式配置  默认: 空（自动探测）
AGENT_DEVICE_IP=127.0.0.1

# 每次 HTTP 上报的超时秒数  默认: 5
INGEST_TIMEOUT_SECONDS=5

# FIO 趋势数据批量上报间隔（秒）  默认: 3
FIO_INGEST_INTERVAL_SECONDS=3

# 磁盘监控数据批量上报间隔（秒）  默认: 3
DISK_INGEST_INTERVAL_SECONDS=3

# 每批次最多上报条数，达到后立即触发上报  默认: 20
INGEST_BATCH_SIZE=20
