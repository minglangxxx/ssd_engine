# ============================================================
# Flask 应用配置
# ============================================================

# 是否开启调试模式（生产环境务必设为 false）默认: false
FLASK_DEBUG=false

# 服务监听地址，0.0.0.0 表示监听所有网卡  默认: 0.0.0.0
APP_HOST=0.0.0.0

# 服务监听端口  默认: 5000
APP_PORT=5000

# Flask Session 签名密钥，生产环境请替换为随机字符串  默认: change_me
SECRET_KEY=change_me

# 日志级别: DEBUG / INFO / WARNING / ERROR  默认: INFO
LOG_LEVEL=INFO

# ============================================================
# MySQL 数据库配置
# ============================================================

# MySQL 主机地址  默认: 127.0.0.1
MYSQL_HOST=127.0.0.1

# MySQL 端口  默认: 3306
MYSQL_PORT=3306

# MySQL 用户名  默认: root
MYSQL_USER=ssd_engine

# MySQL 密码  默认: 空
MYSQL_PASSWORD=123456

# 数据库名  默认: ssd_engine
MYSQL_DATABASE=ssd_engine

# 完整数据库连接串（设置后会覆盖上方 MYSQL_* 配置）  默认: 由上方配置自动拼接
# DATABASE_URL=mysql+pymysql://ssd_engine:123456@127.0.0.1:3306/ssd_engine?charset=utf8mb4

# ============================================================
# AI 分析配置
# ============================================================

# AI 大模型 API Key（留空则 AI 分析功能不可用）  默认: 空
AI_API_KEY=

# AI API 地址  默认: https://api.openai.com/v1
AI_BASE_URL=https://api.openai.com/v1

# AI 模型名称  默认: gpt-4.1
AI_MODEL=gpt-4.1

# AI 分析结果缓存天数，超过后重新分析  默认: 7
AI_ANALYSIS_MAX_AGE_DAYS=7

# ============================================================
# 数据生命周期配置
# ============================================================

# 磁盘监控数据保留天数，超过后每天凌晨 02:00 自动删除  默认: 7
MONITOR_RETENTION_DAYS=7
